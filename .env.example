# Lip Service — environment variables
# Copy to .env, fill in values, then run: source .env

# Anthropic (required)
ANTHROPIC_API_KEY=your_anthropic_key_here

# MailerLite (Advanced plan — required for API campaign creation)
MAILERLITE_API_KEY=your_mailerlite_api_key_here
MAILERLITE_FROM_NAME=Lip Service
MAILERLITE_FROM_EMAIL=hello@yourdomain.com

# Optional overrides (leave blank to use defaults)
# ISSUE_NUMBER=091
# MODE=preview
# BRIEF=
